# Copy to .env.local and fill in your keys (never commit .env.local)

OPENAI_API_KEY=
OPENAI_MODEL=
# Slide video TTS: openai (default if both keys set) or elevenlabs
# AUDIO_TTS_PROVIDER=openai
# OpenAI TTS: https://platform.openai.com/docs/guides/text-to-speech
# OPENAI_TTS_MODEL=tts-1
# OPENAI_TTS_VOICE=nova

TAVILY_API_KEY=

# ElevenLabs — optional; set AUDIO_TTS_PROVIDER=elevenlabs to use when OPENAI is also set
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Optional MySQL — lesson persistence (see README for CREATE TABLE)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=
# MYSQL_LESSONS_TABLE=edugen_lessons
